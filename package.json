{
  "name": "vite-min-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "build:mobile": "vite build --mode mobile",
    "assets:android": "capacitor-assets generate --android --iconBackgroundColor=#051634 --iconBackgroundColorDark=#051634 --splashBackgroundColor=#051634 --splashBackgroundColorDark=#051634 && node scripts/fix-android-assets.cjs",
    "sync:android": "npm run assets:android && npm run build:mobile && cap sync android",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "build:strict": "npm run typecheck && vite build"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@gfazioli/mantine-onboarding-tour": "^4.0.6",
    "@mantine-bites/lightbox": "^2.0.0",
    "@mantine/core": "^9.3.0",
    "@mantine/dates": "^9.3.0",
    "@mantine/form": "^9.3.0",
    "@mantine/hooks": "^9.3.0",
    "@mantine/notifications": "^9.3.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@tabler/icons-react": "^3.34.1",
    "dayjs": "^1.11.21",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "maplibre-gl": "^5.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-map-gl": "^8.1.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.8.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.2",
    "postcss": "^8.5.15",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
